{
  "name": "edithpress",
  "version": "0.1.0",
  "private": true,
  "description": "EdithPress — SaaS CMS Platform",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:seed": "turbo db:seed",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "multer": ">=2.1.1",
      "js-yaml": ">=4.1.1",
      "glob": ">=10.5.0",
      "picomatch": ">=4.0.4",
      "ajv": ">=8.18.0",
      "tmp": ">=0.2.4",
      "webpack": ">=5.104.1",
      "lodash": ">=4.18.1",
      "esbuild": ">=0.25.0"
    }
  },
  "dependencies": {
    "@jridgewell/sourcemap-codec": "^1.5.5",
    "has-flag": "4"
  }
}
