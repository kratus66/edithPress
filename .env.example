# ============================================================
# EdithPress — Environment Variables Contract
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git.
# This file (.env.example) IS committed — it documents all
# required variables with example/placeholder values only.
#
# Legend:
#   # REQUIRED — must be set for the project to run
#   # OPTIONAL — has a fallback or is only needed in production
# ============================================================


# ------------------------------------------------------------
# DATABASE (Postgres)                                REQUIRED
# ------------------------------------------------------------
DATABASE_URL=postgresql://edithpress:devpassword123@localhost:5432/edithpress_dev  # REQUIRED

# Used by docker-compose to create the DB on first run
POSTGRES_DB=edithpress_dev       # REQUIRED
POSTGRES_USER=edithpress         # REQUIRED
POSTGRES_PASSWORD=devpassword123 # REQUIRED


# ------------------------------------------------------------
# REDIS                                              REQUIRED
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379  # REQUIRED


# ------------------------------------------------------------
# JWT / Auth                                         REQUIRED
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 64 characters
# ------------------------------------------------------------
JWT_SECRET=CHANGE_ME_min_64_chars_use_crypto_randomBytes_64         # REQUIRED
JWT_REFRESH_SECRET=CHANGE_ME_min_64_chars_use_crypto_randomBytes_64 # REQUIRED


# ------------------------------------------------------------
# STRIPE                                             REQUIRED (for billing features)
# Get keys at: https://dashboard.stripe.com/test/apikeys
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_CHANGE_ME          # REQUIRED
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME     # REQUIRED
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME        # REQUIRED

# Public key exposed to the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME  # REQUIRED

# Stripe Price IDs per plan + interval (create in Stripe dashboard)
# These are stored in the Plan DB record (stripePriceIdMonthly / stripePriceIdYearly).
# Seed the DB with these values after running prisma migrate dev.
STRIPE_PRICE_STARTER_MONTHLY=price_CHANGE_ME   # OPTIONAL
STRIPE_PRICE_STARTER_YEARLY=price_CHANGE_ME    # OPTIONAL
STRIPE_PRICE_BUSINESS_MONTHLY=price_CHANGE_ME  # OPTIONAL
STRIPE_PRICE_BUSINESS_YEARLY=price_CHANGE_ME   # OPTIONAL
STRIPE_PRICE_PRO_MONTHLY=price_CHANGE_ME       # OPTIONAL
STRIPE_PRICE_PRO_YEARLY=price_CHANGE_ME        # OPTIONAL


# ------------------------------------------------------------
# OBJECT STORAGE (MinIO in dev, S3/R2 in prod)
# ------------------------------------------------------------
# S3-compatible credentials (used by apps/api)       REQUIRED
S3_ENDPOINT=http://localhost:9000         # REQUIRED (leave empty in prod AWS)
S3_ACCESS_KEY=minio_dev                   # REQUIRED
S3_SECRET_KEY=minio_dev_password          # REQUIRED
S3_BUCKET_NAME=edithpress-media           # REQUIRED
S3_REGION=us-east-1                       # REQUIRED

# Legacy AWS_ aliases (kept for SDK compatibility)
AWS_ACCESS_KEY_ID=minio_dev              # REQUIRED
AWS_SECRET_ACCESS_KEY=minio_dev_password # REQUIRED
AWS_BUCKET_NAME=edithpress-media         # REQUIRED
AWS_REGION=us-east-1                     # REQUIRED
AWS_ENDPOINT=http://localhost:9000       # REQUIRED (leave empty in prod AWS)

# MinIO Console credentials (docker-compose only)
MINIO_ROOT_USER=minio_dev          # OPTIONAL (docker-compose dev only)
MINIO_ROOT_PASSWORD=minio_dev_password # OPTIONAL (docker-compose dev only)

# Public CDN URL (exposed to the browser for media URLs)
NEXT_PUBLIC_CDN_URL=http://localhost:9000/edithpress-media # REQUIRED


# ------------------------------------------------------------
# EMAIL                                              OPTIONAL (falls back to console.log)
# Resend in prod: https://resend.com/api-keys
# Mailpit in dev:  http://localhost:8025
# ------------------------------------------------------------
RESEND_API_KEY=re_CHANGE_ME                                # OPTIONAL
RESEND_FROM_EMAIL=EdithPress <noreply@edithpress.com>      # OPTIONAL

# SMTP (used in dev via Mailpit on localhost:1025)
SMTP_HOST=localhost      # OPTIONAL
SMTP_PORT=1025           # OPTIONAL
EMAIL_FROM=noreply@edithpress.com # OPTIONAL


# ------------------------------------------------------------
# APP URLS
# ------------------------------------------------------------
# Admin panel (Next.js — port 3010)
APP_URL=http://localhost:3010            # REQUIRED
NEXT_PUBLIC_APP_URL=http://localhost:3010 # REQUIRED

# NestJS API (port 3011)
API_URL=http://localhost:3011            # REQUIRED
NEXT_PUBLIC_API_URL=http://localhost:3011 # REQUIRED

# Visual editor / builder (Next.js — port 3002)
BUILDER_URL=http://localhost:3002        # OPTIONAL

# Public site renderer (Next.js — port 3003)
RENDERER_URL=http://localhost:3003                  # REQUIRED
NEXT_PUBLIC_RENDERER_URL=http://localhost:3003      # REQUIRED


# ------------------------------------------------------------
# MULTITENANCY
# ------------------------------------------------------------
# Root domain used to build tenant subdomains (tenant.edithpress.com)
ROOT_DOMAIN=localhost  # REQUIRED


# ------------------------------------------------------------
# RENDERER / PREVIEW
# ------------------------------------------------------------
# Shared secret between builder and renderer for preview requests.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RENDERER_SECRET=CHANGE_ME_min_32_chars_use_crypto_randomBytes_32  # REQUIRED

# Same secret exposed to the browser (builder uses it to call the renderer's revalidate endpoint)
NEXT_PUBLIC_RENDERER_SECRET=CHANGE_ME_min_32_chars_use_crypto_randomBytes_32  # REQUIRED

# Internal URL used by the renderer to call the NestJS API (server-to-server)
# In Docker/production use the internal service name (e.g. http://api:3011)
API_INTERNAL_URL=http://localhost:3011  # REQUIRED


# ------------------------------------------------------------
# NEXT AUTH                                          OPTIONAL
# Used by Next.js middleware / session management
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ------------------------------------------------------------
NEXTAUTH_SECRET=CHANGE_ME_nextauth_secret  # OPTIONAL


# ------------------------------------------------------------
# SENTRY (error tracking)                            OPTIONAL
# Get DSN at: https://sentry.io
# ------------------------------------------------------------
SENTRY_DSN=CHANGE_ME             # OPTIONAL
NEXT_PUBLIC_SENTRY_DSN=CHANGE_ME # OPTIONAL


# ------------------------------------------------------------
# MISC
# ------------------------------------------------------------
NODE_ENV=development  # REQUIRED
LOG_LEVEL=debug       # OPTIONAL
