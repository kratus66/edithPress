# ============================================================
# EdithPress — Environment Variables Contract
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git.
# This file (.env.example) IS committed — it documents all
# required variables with example/placeholder values only.
# ============================================================


# ------------------------------------------------------------
# DATABASE (Postgres)
# ------------------------------------------------------------
DATABASE_URL=postgresql://edithpress:devpassword123@localhost:5432/edithpress_dev

# Used by docker-compose to create the DB on first run
POSTGRES_DB=edithpress_dev
POSTGRES_USER=edithpress
POSTGRES_PASSWORD=devpassword123


# ------------------------------------------------------------
# REDIS
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379


# ------------------------------------------------------------
# JWT / Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 64 characters
# ------------------------------------------------------------
JWT_SECRET=CHANGE_ME_min_64_chars_use_crypto_randomBytes_64
JWT_REFRESH_SECRET=CHANGE_ME_min_64_chars_use_crypto_randomBytes_64


# ------------------------------------------------------------
# STRIPE
# Get keys at: https://dashboard.stripe.com/test/apikeys
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# Stripe Price IDs (create in Stripe dashboard)
STRIPE_PRICE_STARTER=price_CHANGE_ME
STRIPE_PRICE_PRO=price_CHANGE_ME
STRIPE_PRICE_ENTERPRISE=price_CHANGE_ME


# ------------------------------------------------------------
# OBJECT STORAGE (MinIO in dev, Cloudflare R2 in prod)
# ------------------------------------------------------------
AWS_ACCESS_KEY_ID=minio_dev
AWS_SECRET_ACCESS_KEY=minio_dev_password
AWS_BUCKET_NAME=edithpress-media
AWS_REGION=us-east-1
# Leave empty in prod (uses default AWS endpoint)
AWS_ENDPOINT=http://localhost:9000

# MinIO Console credentials (docker-compose only)
MINIO_ROOT_USER=minio_dev
MINIO_ROOT_PASSWORD=minio_dev_password


# ------------------------------------------------------------
# EMAIL (Mailpit in dev, Resend in prod)
# ------------------------------------------------------------
# Resend API key (prod): https://resend.com/api-keys
RESEND_API_KEY=CHANGE_ME

# SMTP (used in dev via Mailpit on localhost:1025)
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM=noreply@edithpress.com


# ------------------------------------------------------------
# APP URLS
# ------------------------------------------------------------
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
BUILDER_URL=http://localhost:3002
RENDERER_URL=http://localhost:3003

# Next.js public env vars (exposed to the browser)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME


# ------------------------------------------------------------
# MULTITENANCY
# ------------------------------------------------------------
# Root domain used to build tenant subdomains (tenant.edithpress.com)
ROOT_DOMAIN=localhost


# ------------------------------------------------------------
# RENDERER / PREVIEW
# ------------------------------------------------------------
# Shared secret between builder and renderer to authenticate preview requests.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used by:
#   - apps/builder (RENDERER_SECRET)  → sent as ?secret= in the preview redirect
#   - apps/renderer (RENDERER_SECRET) → validated in /api/preview route handler
RENDERER_SECRET=CHANGE_ME_min_32_chars_use_crypto_randomBytes_32

# Public URL of the renderer (used by the preview route to build the tenant redirect URL)
# Dev:  http://localhost:3003
# Prod: https://edithpress.com  (tenants access as {slug}.edithpress.com)
RENDERER_PUBLIC_URL=http://localhost:3003

# Internal URL used by the renderer to call the NestJS API (server-to-server, never public)
# In Docker / production this can be the internal service name (e.g. http://api:3001)
API_INTERNAL_URL=http://localhost:3001


# ------------------------------------------------------------
# SENTRY (error tracking — optional in dev)
# Get DSN at: https://sentry.io
# ------------------------------------------------------------
SENTRY_DSN=CHANGE_ME
NEXT_PUBLIC_SENTRY_DSN=CHANGE_ME


# ------------------------------------------------------------
# MISC
# ------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug
