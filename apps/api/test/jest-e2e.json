{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "\\.(e2e-spec|test)\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", {
      "tsconfig": "<rootDir>/tsconfig.spec.json",
      "diagnostics": false
    }]
  },
  "moduleNameMapper": {
    "^@edithpress/(.*)$": "<rootDir>/../../packages/$1/src/index"
  }
}
