# ============================================================
# EdithPress — Renderer (apps/renderer) Environment Variables
# ============================================================
# Copy this file to apps/renderer/.env.local and fill in values.
#   cp apps/renderer/.env.example apps/renderer/.env.local
#
# Root .env.example documents the full project-level contract.
# This file documents only the variables consumed by the renderer.
# ============================================================


# ------------------------------------------------------------
# API — Public URL (exposed to the browser)
# Used by: NewsletterBlock, FooterNewsletter (client components)
# In prod: https://api.edithpress.com
# ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001  # REQUIRED


# ------------------------------------------------------------
# API — Internal URL (server-to-server, never exposed to browser)
# Used by: page SSR, contact proxy, robots.ts, sitemap.ts
# In Docker/production use the internal service name, e.g. http://api:3011
# ------------------------------------------------------------
API_INTERNAL_URL=http://localhost:3001  # REQUIRED


# ------------------------------------------------------------
# RENDERER SECRET
# Shared secret between builder and renderer for preview/revalidate requests.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match RENDERER_SECRET in apps/builder and apps/api.
# ------------------------------------------------------------
RENDERER_SECRET=CHANGE_ME_min_32_chars_use_crypto_randomBytes_32  # REQUIRED


# ------------------------------------------------------------
# RENDERER PUBLIC URL
# Used by the preview API route to build redirect URLs.
# In prod: https://renderer.edithpress.com or tenant subdomain base.
# ------------------------------------------------------------
RENDERER_PUBLIC_URL=http://localhost:3003  # REQUIRED


# ------------------------------------------------------------
# MULTITENANCY
# Root domain used to resolve tenant slugs from Host header.
# ------------------------------------------------------------
ROOT_DOMAIN=localhost  # REQUIRED


# ------------------------------------------------------------
# MISC
# ------------------------------------------------------------
NODE_ENV=development  # REQUIRED
